rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // レビュー：誰でも閲覧可。投稿は匿名ログイン済みかつ自分のuserIdでのみ可能。
    // 編集・削除機能はアプリ未実装のため拒否（実装時にオーナー限定の update/delete を追加すること）。
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.body is string
                    && request.resource.data.body.size() <= 2000
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;
      allow update, delete: if false;
    }

    // 応援メッセージ：誰でも閲覧可。投稿はログイン済み（匿名含む）であれば可能。
    match /cheers/{cheerId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.message is string
                    && request.resource.data.message.size() <= 280;
      allow update, delete: if false;
    }

    // 上記以外のコレクションはデフォルトで拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
